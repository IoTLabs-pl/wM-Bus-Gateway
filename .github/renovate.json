{
  "extends": ["config:recommended"],
  "customManagers": [
    {
      "managerFilePatterns": ["packages/version.yaml"],
      "fileFormat": "yaml",
      "customType": "jsonata",
      "matchStrings": [
        "substitutions.{\"currentValue\":esphome_components_version}"
      ],
      "packageNameTemplate": "IoTLabs-pl/ESPHome-Components",
      "datasourceTemplate": "github-releases"
    },
    {
      "managerFilePatterns": [".github/workflows/build.yaml"],
      "fileFormat": "yaml",
      "customType": "jsonata",
      "matchStrings": [
        "jobs.build.steps[id=\"build_firmware\"].{\"currentValue\":with.version}"
      ],
      "packageNameTemplate": "esphome/esphome",
      "datasourceTemplate": "github-releases"
    }
  ]
}
